# Keep source, configuration, and documentation line endings stable.
* text=auto

*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.json text eol=lf
.gitattributes text eol=lf
*.gitignore text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf
mvnw text eol=lf

*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
